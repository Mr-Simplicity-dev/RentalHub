# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rentalhub

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=generate_a_random_64_hex_char_string
JWT_EXPIRY=7d

# ─── Authentication ──────────────────────────────────────
COOKIE_AUTH_STRICT=true
RETURN_AUTH_TOKEN_IN_BODY=false
# Cookie domain (set to your domain in production)
COOKIE_DOMAIN=

# ─── Payments ────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...

# ─── File Uploads ────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email ───────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=RentalHub NG <support@yourdomain.com>
EMAIL_REPLY_TO=support@yourdomain.com

# ─── SMS ─────────────────────────────────────────────────
TERMII_API_KEY=your_termii_key
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
SMS_WEBHOOK_SECRET=generate_a_unique_random_string

# ─── Identity Verification (Prembly) ─────────────────────
ALLOW_TEST_NIN_BYPASS=false
NIMC_TEST_NIN=00000000000
NIN_ENCRYPTION_KEY=generate_a_64_hex_char_key_with_node_-e_console.log_require(crypto).randomBytes(32).toString('hex')
PREMBLY_API_KEY=your_prembly_api_key
PREMBLY_APP_ID=your_prembly_app_id
PREMBLY_API_URL=https://api.prembly.com

# ─── Maps ────────────────────────────────────────────────
REACT_APP_GOOGLE_MAPS_KEY=your_google_maps_api_key

# ─── AI ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── SEO ranking tracker ─────────────────────────────────────────────
# One SerpAPI search credit is used per keyword on each scheduled run.
SERP_API_KEY=your_serpapi_key
SEO_RANKING_TARGET_URL=https://rentalhub.com.ng
SEO_RANKING_KEYWORDS=houses for rent in ikeja,apartments for rent in lagos
SEO_RANKING_SEARCH_DEPTH=100
SEO_RANKING_COUNTRY=ng
SEO_RANKING_LANGUAGE=en
SEO_RANKING_CRON=0 3 * * *

# ─── Proxy ───────────────────────────────────────────────
TRUST_PROXY_COUNT=1

# ─── Webhook ─────────────────────────────────────────────
# SMS delivery webhook — MUST be unique, DO NOT reuse JWT_SECRET
SMS_WEBHOOK_SECRET=generate_a_unique_random_secret

# ─── Rate Limiting (optional overrides) ──────────────────
AUTH_SENSITIVE_WINDOW_MS=600000
AUTH_SENSITIVE_MAX=25
CONTACT_FORM_WINDOW_MS=900000
CONTACT_FORM_MAX=5
