# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rentalhub

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=generate_a_random_64_hex_char_string
JWT_EXPIRY=7d

# ─── Authentication ──────────────────────────────────────
COOKIE_AUTH_STRICT=true
RETURN_AUTH_TOKEN_IN_BODY=false
# Cookie domain (set to your domain in production)
COOKIE_DOMAIN=

# ─── Payments ────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...

# ─── File Uploads ────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email ───────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=RentalHub NG <support@yourdomain.com>
EMAIL_REPLY_TO=support@yourdomain.com

# ─── SMS ─────────────────────────────────────────────────
TERMII_API_KEY=your_termii_key
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
SMS_WEBHOOK_SECRET=generate_a_unique_random_string

# ─── Identity Verification ───────────────────────────────
ALLOW_TEST_NIN_BYPASS=false
NIMC_TEST_NIN=00000000000
NIN_ENCRYPTION_KEY=64_hex_char_encryption_key_for_nin

# ─── Maps ────────────────────────────────────────────────
REACT_APP_GOOGLE_MAPS_KEY=your_google_maps_api_key

# ─── AI ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Proxy ───────────────────────────────────────────────
TRUST_PROXY_COUNT=1

# ─── Webhook ─────────────────────────────────────────────
# Used by external services to send events back to the platform
WEBHOOK_SECRET=your_webhook_secret

# ─── Rate Limiting (optional overrides) ──────────────────
AUTH_SENSITIVE_WINDOW_MS=600000
AUTH_SENSITIVE_MAX=25
CONTACT_FORM_WINDOW_MS=900000
CONTACT_FORM_MAX=5
