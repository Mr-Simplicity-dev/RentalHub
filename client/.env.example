# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rental_platform
DB_USER=postgres
DB_PASSWORD=your_database_password

#Mongodb
MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/database

# Application
APP_PORT=5000
NODE_ENV=development
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Payment Gateway (Paystack - Popular in Nigeria)
PAYSTACK_SECRET_KEY=your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=your_paystack_public_key


# File Upload (Cloudinary or AWS S3)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret


# Frontend URL
FRONTEND_URL=http://localhost:3000
PRODUCTION_FRONTEND_URL=https://rentalhub.com.ng
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://rentalhub.com.ng,https://www.rentalhub.com.ng

REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_PAYSTACK_PUBLIC_KEY=your_paystack_public_key

RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=RentalHub NG <support@rentalhub.com.ng>
EMAIL_REPLY_TO=support@rentalhub.com.ng

# SEO / Search Console
SERP_API_KEY=your_serp_api_key
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=service-account.json
GOOGLE_INDEXING_KEY_FILE=service-account.json
GSC_KEY_FILE=service-account.json
GSC_SITE_URL=https://rentalhub.com.ng
# GSC_START_DATE=2026-01-01
# GSC_END_DATE=2026-12-31

# GOOGLE_MAPS
REACT_APP_GOOGLE_MAPS_KEY=your_google_maps_browser_key

# Identity verification integrations
# Allow test NIN during development only (set false on production)
ALLOW_TEST_NIN_BYPASS=true
NIMC_TEST_NIN=00000000000

# NIMC (required for real local registrations)
NIMC_API_URL=
NIMC_API_KEY=
NIMC_AUTH_SCHEME=Bearer
NIMC_API_TIMEOUT_MS=12000

# Passport API (required for foreign registrations)
PASSPORT_API_URL=
PASSPORT_API_KEY=
PASSPORT_AUTH_SCHEME=Bearer
PASSPORT_API_TIMEOUT_MS=12000


WHATSAPP_PROVIDER=meta
WHATSAPP_META_TOKEN=...
WHATSAPP_PHONE_NUMBER_ID=...

# AI damage Analysis
ANTHROPIC_API_KEY=your_anthropic_api_key


# Termii
# SMS Service (Twilio or Termii for Nigeria)
TERMII_API_KEY=your_termii_api_key
TERMII_BASE_URL=https://v3.api.termii.com
TERMII_SENDER_ID=RentalHub
TERMII_CHANNEL=generic

# SMS provider order
SMS_PROVIDER_ORDER=termii,twilio
SMS_TIMEOUT_MS=15000

# Delivery webhook security
SMS_STATUS_CALLBACK_BASE_URL=https://rentalhub.com.ng
SMS_WEBHOOK_SECRET=generate_a_long_random_secret_here

# Optional fallback timing
SMS_TIMEOUT_FALLBACK_ENABLED=true
SMS_FALLBACK_AFTER_SECONDS=120
SMS_FALLBACK_CRON=* * * * *
